# SentinelOps Configuration File
# Enterprise System Monitoring & Remediation Suite
# Version: 2.0

# ============================================
# GLOBAL SETTINGS
# ============================================

# Default output directory for reports
# OUTPUT_DIR="./logs"

# Default backup directory
# BACKUP_DIR="./backups"

# Maximum report file size in MB before rotation
# MAX_REPORT_SIZE=10

# Number of report files to keep
# REPORT_RETENTION=5

# ============================================
# SCANNER SETTINGS
# ============================================

# Enable/disable specific scan modules
# ENABLE_DISK_SCAN=true
# ENABLE_PROCESS_SCAN=true
# ENABLE_NETWORK_SCAN=true
# ENABLE_SECURITY_SCAN=true
# ENABLE_PERFORMANCE_SCAN=true

# Quick scan threshold values
# DISK_USAGE_WARNING=85
# DISK_USAGE_CRITICAL=95
# MEMORY_USAGE_WARNING=80
# MEMORY_USAGE_CRITICAL=90

# ============================================
# FIXER SETTINGS
# ============================================

# Default operation mode
# DEFAULT_MODE="interactive"  # Options: interactive, auto-confirm, dry-run

# Backup strategy
# BACKUP_STRATEGY="full"  # Options: full, minimal, none

# High-risk operation confirmation
# CONFIRM_HIGH_RISK=true

# ============================================
# SECURITY SETTINGS
# ============================================

# SSH security settings
# SSH_PERMIT_ROOT_LOGIN="no"
# SSH_PASSWORD_AUTHENTICATION="no"
# SSH_DEFAULT_PORT=2222

# Firewall settings
# ENABLE_FIREWALL=true
# FIREWALL_DEFAULT_POLICY="deny"

# ============================================
# PERFORMANCE SETTINGS
# ============================================

# Memory optimization
# MEMORY_SWAPPINESS=10
# MEMORY_DROP_CACHES=false

# Disk optimization
# DISK_CLEANUP_AGE=7  # Days
# DISK_TEMP_CLEANUP=true

# ============================================
# NOTIFICATION SETTINGS
# ============================================

# Email notifications
# EMAIL_NOTIFICATIONS=false
# SMTP_SERVER="smtp.example.com"
# SMTP_PORT=587
# SMTP_USER="user@example.com"
# SMTP_PASSWORD="password"
# NOTIFICATION_EMAIL="admin@example.com"

# ============================================
# LOGGING SETTINGS
# ============================================

# Log level
# LOG_LEVEL="info"  # Options: debug, info, warning, error

# Log file rotation
# LOG_ROTATION="daily"  # Options: daily, weekly, monthly, none

# ============================================
# END OF CONFIGURATION
# ============================================

# Note: This configuration file uses a simple key=value format.
# Lines starting with # are comments and are ignored.
# To override default settings, uncomment the appropriate lines
# and modify the values as needed.
